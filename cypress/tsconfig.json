{
    "compilerOptions": {
        "target": "ES2019",
        "lib": ["ES2019", "dom"],
        "module": "CommonJS",
        "moduleResolution": "Node",
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "types": ["cypress", "node"]
    },
    "include": ["e2e/**/*.ts", "support/**/*.ts", "test-app/**/*.ts", "../cypress.config.ts"]
}
